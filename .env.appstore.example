# ==============================================================================
# Informity AI — Local macOS App Store env template
# Copy to .env.appstore and fill values (this file is gitignored).
# ==============================================================================

# App signing identity used by Tauri for Mac App Store app bundle signing.
APPLE_APPSTORE_SIGNING_IDENTITY="Apple Distribution: Your Name (TEAMID)"

# Installer signing identity used by productbuild for .pkg.
APPLE_APPSTORE_INSTALLER_IDENTITY="3rd Party Mac Developer Installer: Your Name (TEAMID)"

# App Store Connect API credentials.
APPLE_API_ISSUER="YOUR_ISSUER_ID_UUID"
APPLE_API_KEY="YOUR_KEY_ID"
APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_YOUR_KEY_ID.p8"

# Optional validations/overrides.
APPLE_APPSTORE_PROVISION_PROFILE_PATH="/absolute/path/to/mac-app-store.provisionprofile"
TAURI_APP_NAME="Informity AI"
TAURI_APPSTORE_TARGET="universal-apple-darwin"
